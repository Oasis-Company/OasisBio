// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  oasisBios     OasisBio[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OasisBio {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  title         String
  slug          String        @unique
  tagline       String?
  identityMode  String        @default("real")
  birthDate     DateTime?
  gender        String?
  pronouns      String?
  placeOfOrigin String?
  currentEra    String?
  species       String?
  status        String?
  description   String?
  visibility    String        @default("private")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  abilities     Ability[]
  dcosFiles     DcosFile[]
  references    ReferenceItem[]
  worlds        WorldItem[]
  models        ModelItem[]
  eras          EraIdentity[]

  @@map("oasis_bios")
}

model EraIdentity {
  id        String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  name      String
  eraType   String
  startDate DateTime?
  endDate   DateTime?
  description String?
  oasisBio  OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("era_identities")
}

model Ability {
  id            String    @id @default(cuid())
  oasisBioId    String    @map("oasis_bio_id")
  name          String
  category      String
  type          String    @default("custom")
  level         Int       @default(1)
  description   String?
  relatedWorldId String?
  relatedEraId  String?
  oasisBio      OasisBio  @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("abilities")
}

model DcosFile {
  id        String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  title     String
  content   String
  folder    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  oasisBio  OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("dcos_files")
}

model ReferenceItem {
  id          String   @id @default(cuid())
  oasisBioId  String   @map("oasis_bio_id")
  url         String
  title       String
  type        String
  description String?
  tags        String
  oasisBio    OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("reference_items")
}

model WorldItem {
  id        String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  name      String
  summary   String
  timeline  String?
  rules     String?
  factions  String?
  oasisBio  OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("world_items")
}

model ModelItem {
  id            String   @id @default(cuid())
  oasisBioId    String   @map("oasis_bio_id")
  name          String
  objUrl        String
  mtlUrl        String?
  previewImage  String?
  relatedWorldId String?
  relatedEraId  String?
  oasisBio      OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("model_items")
}

